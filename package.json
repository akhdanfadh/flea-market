{
  "name": "flea-market",
  "private": true,
  "description": "Self-hosted single-admin flea-market listing app on Cloudflare Workers.",
  "license": "MIT",
  "author": "Akhdan Fadhilah",
  "repository": "github:akhdanfadh/flea-market",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "cf-typegen": "wrangler types",
    "db:check": "node --no-warnings=ExperimentalWarning scripts/db-check.ts",
    "db:local": "mkdir -p .turso && turso dev --db-file .turso/local.db",
    "db:push": "drizzle-kit push",
    "db:seed": "node --no-warnings=ExperimentalWarning scripts/seed.ts",
    "db:studio": "drizzle-kit studio",
    "deploy": "pnpm run build && wrangler deploy",
    "dev": "vite dev --port 3000",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "prepare": "lefthook install",
    "preview": "vite preview",
    "r2:prune": "node --no-warnings=ExperimentalWarning scripts/r2-prune-orphans.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@cloudflare/vite-plugin": "^1.26.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/noto-sans": "^5.2.10",
    "@fontsource-variable/noto-sans-jp": "^5.2.10",
    "@hookform/resolvers": "^5.2.2",
    "@icons-pack/react-simple-icons": "^13.13.0",
    "@libsql/client": "^0.17.3",
    "@standard-schema/spec": "^1.1.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^0.545.0",
    "nanoid": "^5.1.11",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.75.0",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1047.0",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^28.1.0",
    "lefthook": "^2.1.6",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.70.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
